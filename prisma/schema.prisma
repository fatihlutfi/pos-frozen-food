generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

model Branch {
  id            String                @id @default(cuid())
  name          String                @unique
  address       String?
  phone         String?
  isActive      Boolean               @default(true)
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
  shifts        CashierShift[]
  batches       ProductBatch[]
  discountRules ProductDiscountRule[]
  stockLogs     StockLog[]
  stockOpnames  StockOpname[]
  stocks        Stock[]
  transactions  Transaction[]
  users         User[]

  @@map("branches")
}

model User {
  id           String         @id @default(cuid())
  name         String
  email        String         @unique
  password     String
  role         Role           @default(KASIR)
  isActive     Boolean        @default(true)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  branchId     String?
  shifts       CashierShift[]
  stockLogs    StockLog[]
  stockOpnames StockOpname[]
  transactions Transaction[]
  branch       Branch?        @relation(fields: [branchId], references: [id])

  @@map("users")
}

model Category {
  id        String    @id @default(cuid())
  name      String    @unique
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  products  Product[]

  @@map("categories")
}

model Product {
  id               String                @id @default(cuid())
  name             String                @unique
  description      String?
  price            Int
  imageUrl         String?
  isActive         Boolean               @default(true)
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  categoryId       String
  costPrice        Int                   @default(0)
  batches          ProductBatch[]
  discountRules    ProductDiscountRule[]
  category         Category              @relation(fields: [categoryId], references: [id])
  stockLogs        StockLog[]
  opnameItems      StockOpnameItem[]
  stocks           Stock[]
  transactionItems TransactionItem[]

  @@index([categoryId, isActive])
  @@index([isActive, name])
  @@map("products")
}

model Stock {
  id            String   @id @default(cuid())
  quantity      Int      @default(0)
  lowStockAlert Int      @default(10)
  updatedAt     DateTime @updatedAt
  productId     String
  branchId      String
  branch        Branch   @relation(fields: [branchId], references: [id])
  product       Product  @relation(fields: [productId], references: [id])

  @@unique([productId, branchId])
  @@map("stocks")
}

model StockLog {
  id            String       @id @default(cuid())
  type          StockLogType
  change        Int
  noteBefore    Int
  noteAfter     Int
  note          String?
  createdAt     DateTime     @default(now())
  productId     String
  branchId      String
  userId        String?
  transactionId String?
  branch        Branch       @relation(fields: [branchId], references: [id])
  product       Product      @relation(fields: [productId], references: [id])
  transaction   Transaction? @relation(fields: [transactionId], references: [id])
  user          User?        @relation(fields: [userId], references: [id])

  @@index([branchId, createdAt(sort: Desc)])
  @@index([productId, branchId, createdAt(sort: Desc)])
  @@index([transactionId])
  @@map("stock_logs")
}

model Transaction {
  id             String            @id @default(cuid())
  invoiceNumber  String            @unique
  paymentMethod  PaymentMethod
  status         TransactionStatus @default(COMPLETED)
  subtotal       Int
  discountAmount Int               @default(0)
  grandTotal     Int
  amountPaid     Int
  changeAmount   Int               @default(0)
  note           String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  branchId       String
  userId         String
  voidReason     String?
  voidedAt       DateTime?
  shiftId        String?
  stockLogs      StockLog[]
  items          TransactionItem[]
  branch         Branch            @relation(fields: [branchId], references: [id])
  shift          CashierShift?     @relation(fields: [shiftId], references: [id])
  user           User              @relation(fields: [userId], references: [id])

  @@index([branchId, createdAt(sort: Desc)])
  @@index([branchId, status, createdAt(sort: Desc)])
  @@index([shiftId])
  @@index([userId, createdAt(sort: Desc)])
  @@map("transactions")
}

model TransactionItem {
  id              String      @id @default(cuid())
  quantity        Int
  price           Int
  subtotal        Int
  createdAt       DateTime    @default(now())
  transactionId   String
  productId       String
  costPrice       Int         @default(0)
  discountPercent Float       @default(0)
  product         Product     @relation(fields: [productId], references: [id])
  transaction     Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([transactionId])
  @@map("transaction_items")
}

model CashierShift {
  id             String        @id @default(cuid())
  status         ShiftStatus   @default(OPEN)
  openingBalance Int
  closingBalance Int?
  note           String?
  openedAt       DateTime      @default(now())
  closedAt       DateTime?
  userId         String
  branchId       String
  branch         Branch        @relation(fields: [branchId], references: [id])
  user           User          @relation(fields: [userId], references: [id])
  transactions   Transaction[]

  @@index([branchId, status, openedAt(sort: Desc)])
  @@index([userId, status])
  @@map("cashier_shifts")
}

model StockOpname {
  id          String            @id @default(cuid())
  status      StockOpnameStatus @default(DRAFT)
  note        String?
  confirmedAt DateTime?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @default(now()) @updatedAt
  branchId    String
  userId      String
  items       StockOpnameItem[]
  branch      Branch            @relation(fields: [branchId], references: [id])
  user        User              @relation(fields: [userId], references: [id])

  @@map("stock_opnames")
}

model StockOpnameItem {
  id          String      @id @default(cuid())
  systemQty   Int
  physicalQty Int?
  opnameId    String
  productId   String
  opname      StockOpname @relation(fields: [opnameId], references: [id], onDelete: Cascade)
  product     Product     @relation(fields: [productId], references: [id])

  @@unique([opnameId, productId])
  @@map("stock_opname_items")
}

model ProductBatch {
  id             String    @id @default(cuid())
  batchCode      String
  productionDate DateTime?
  expiryDate     DateTime
  quantity       Int       @default(0)
  initialQty     Int       @default(0)
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @default(now()) @updatedAt
  productId      String
  branchId       String
  branch         Branch    @relation(fields: [branchId], references: [id])
  product        Product   @relation(fields: [productId], references: [id])

  @@index([productId, branchId, expiryDate])
  @@map("product_batches")
}

model ProductDiscountRule {
  id              String   @id @default(cuid())
  minQty          Int
  discountPercent Float
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  productId       String
  branchId        String
  branch          Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  product         Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, branchId, minQty])
  @@map("product_discount_rules")
}

enum Role {
  ADMIN
  KASIR
}

enum PaymentMethod {
  CASH
  TRANSFER_BANK
  QRIS
}

enum TransactionStatus {
  COMPLETED
  VOIDED
}

enum ShiftStatus {
  OPEN
  CLOSED
}

enum StockLogType {
  SALE
  ADJUSTMENT
  INITIAL
  RETURN
  OPNAME
}

enum StockOpnameStatus {
  DRAFT
  CONFIRMED
}

