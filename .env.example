# =============================================================
# Environment Variables — POS Frozen Food
# Salin file ini ke .env dan isi nilainya untuk local development
# JANGAN commit .env ke git — sudah di-ignore via .gitignore
# =============================================================

# --- Database (Supabase) ---
# Gunakan pooler URL (port 6543) dengan pgbouncer=true untuk runtime
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/DATABASE?pgbouncer=true"

# Gunakan direct URL (port 5432) untuk prisma migrate
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE"

# --- NextAuth ---
# URL aplikasi — gunakan http://localhost:3000 untuk local dev
NEXTAUTH_URL="http://localhost:3000"

# Secret untuk JWT signing — generate dengan: openssl rand -base64 32
# Production secret dikelola di Vercel env vars, BUKAN di sini
NEXTAUTH_SECRET="your-local-dev-secret-here"
